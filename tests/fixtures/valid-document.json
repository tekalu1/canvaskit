      "sm": { "value": "640px" },
      "md": { "value": "768px" },
      "lg": { "value": "1024px" },
      "xl": { "value": "1280px" }
    }
  },
  "components": {
    "Button": {
      "description": "Primary action button",
      "variants": {
        "size": {
          "sm": { "padding": "8px 16px", "fontSize": "14px" },
          "md": { "padding": "12px 24px", "fontSize": "16px" },
          "lg": { "padding": "16px 32px", "fontSize": "18px" }
        }
      },
      "props": ["text", "variant", "disabled"],
      "defaultProps": { "text": "Click me", "variant": "primary", "disabled": false },
      "template": {
        "type": "frame",
        "styles": {
          "backgroundColor": "{colors.primary}",
          "borderRadius": "{borderRadius.md}",
          "padding": "12px 24px"
        },
        "children": [
          {
            "type": "text",
            "content": "Click me",
            "styles": { "color": "#ffffff", "fontWeight": "semibold" }
          }
        ]
      }
    },
    "Card": {
      "description": "Content card container",
      "variants": {},
      "props": ["title"],
      "defaultProps": { "title": "Card Title" }
    }
  },
  "pages": {
    "page1": {
      "name": "Home",
      "width": 1440,
      "height": null,
      "nodes": {
        "root": {
          "type": "frame",
          "name": "Root",
          "layout": { "direction": "column" },
          "children": ["header", "main"],
          "styles": { "width": "100%", "minHeight": "100vh" }
        },
        "header": {
          "type": "frame",
          "name": "Header",
          "layout": { "direction": "row", "justify": "between", "align": "center" },
          "children": ["logo", "nav"],
          "styles": { "padding": "16px 32px", "backgroundColor": "#ffffff" }
        },
        "logo": {
          "type": "text",
          "name": "Logo",
          "content": "CanvasKit",
          "styles": { "fontSize": "24px", "fontWeight": "bold" }
        },
        "nav": {
          "type": "frame",
          "name": "Navigation",
          "layout": { "direction": "row", "gap": "16px" },
          "children": ["nav-home", "nav-about"],
          "styles": {}
        },
        "nav-home": {
          "type": "text",
          "name": "Nav Home",
          "content": "Home",
          "styles": { "color": "#3B82F6" }
        },
        "nav-about": {
          "type": "text",
          "name": "Nav About",
          "content": "About",
          "styles": {}
        },
        "main": {
          "type": "frame",
          "name": "Main Content",
          "layout": { "direction": "column", "gap": "24px" },
          "children": ["hero-title", "hero-image", "cta-button"],
          "styles": { "padding": "48px 32px" }
        },
        "hero-title": {
          "type": "text",
          "name": "Hero Title",
          "content": "Design with Code",
          "styles": { "fontSize": "48px", "fontWeight": "bold", "color": "#111827" }
        },
        "hero-image": {
          "type": "image",
          "name": "Hero Image",
          "src": "https://example.com/hero.png",
          "alt": "Hero banner",
          "styles": { "width": "100%", "height": "400px", "borderRadius": "16px" }
        },
        "cta-button": {
          "type": "component",
          "name": "CTA Button",
          "componentRef": "Button",
          "props": { "text": "Get Started", "variant": "primary" },
          "overrides": {},
          "styles": {}
        }
      }
    },
    "page2": {
      "name": "About",
      "width": 1440,
      "height": null,
      "nodes": {
        "root": {
          "type": "frame",
          "name": "Root",
          "layout": { "direction": "column" },
          "children": [],
          "styles": {}
        }
      }
    }
